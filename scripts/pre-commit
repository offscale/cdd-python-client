#!/usr/bin/env bash

set -e

echo "[pre-commit] Auto-formatting code..."
uv run ruff format .

echo "[pre-commit] Checking code formatting..."
uv run ruff format --check .

echo "[pre-commit] Linting code (auto-fix)..."
uv run ruff check --fix .

echo "[pre-commit] Checking linting..."
uv run ruff check .

echo "[pre-commit] Building project..."
uv run python -m build

echo "[pre-commit] Calculating coverage and updating badges..."
uv run python scripts/update_badges.py

if git diff --name-only | grep -q "README.md"; then
    echo "[pre-commit] README.md was updated with new coverage badges. Staging changes..."
    git add README.md
fi
