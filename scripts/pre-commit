#!/usr/bin/env bash

set -e

echo "[pre-commit] Auto-formatting code..."
uv run ruff format .

echo "[pre-commit] Checking code formatting..."
uv run ruff format --check .

echo "[pre-commit] Linting code (auto-fix)..."
uv run ruff check --fix .

echo "[pre-commit] Checking linting..."
uv run ruff check .

echo "[pre-commit] Building project..."
uv build

echo "[pre-commit] Running tests and updating badges..."
uv run python scripts/update_badges.py

TEST_HARNESS=${TEST_HARNESS_DIR:-/Users/samuel/repos/cdd-openapi-test-harness}

echo "[pre-commit] Running Swagger 2.0 Petstore test..."
uv run cdd-python from_openapi to_sdk_cli -i "$TEST_HARNESS/petstore.json" -o .tmp_swagger
rm -rf .tmp_swagger

echo "[pre-commit] Running OpenAPI 3.2.0 Petstore test..."
uv run cdd-python from_openapi to_sdk_cli -i "$TEST_HARNESS/petstore_oas3.json" -o .tmp_oas3
rm -rf .tmp_oas3

echo "[pre-commit] Building WASM..."
make build_wasm

if git diff --name-only | grep -q "README.md"; then
    echo "[pre-commit] README.md was updated with new coverage badges. Staging changes..."
    git add README.md
fi
